# --- General / Environment Files ---
# Ignore environment variables. These contain secrets like database passwords.
.env
.env.*
# But DO track an example file so others know what variables are needed.
!/.env.example

# --- Python / Django Backend ---
# Virtual environment folder. This is specific to your machine and can be very large.
.venv/
venv/
env/

# Python cache files. These are auto-generated.
__pycache__/
*.pyc

# Development database. The database itself should not be in version control,
# only the migration files (the "blueprint" for the database).
backend/db.sqlite3

# User-uploaded media files and collected static files.
# These should be handled by your deployment server's storage (like S3).
backend/media/
backend/staticfiles/

# Log files
*.log


# --- React / Node.js Frontend ---
# The massive folder of all your npm package dependencies.
# Can be re-created by running "npm install".
frontend/node_modules/

# The production build folder. This is generated by "npm run build".
frontend/build/

# Log files for npm and yarn
npm-debug.log*
yarn-error.log*


# --- IDE / Editor Configuration ---
# These are specific to your code editor (VSCode, PyCharm, etc.).
.vscode/
.idea/


# --- Operating System Generated Files ---
# macOS
.DS_Store

# Windows
Thumbs.db